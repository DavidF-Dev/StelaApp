<?xml version="1.0" encoding="utf-8"?>
<!-- INTERNET is never declared: the app is offline by design. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".StelaApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Stela">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stela.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share target: plain text shared from another app becomes a new note. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!--
          No-UI trampoline for the "New quick note" launcher shortcut. Exported (the launcher is another
          app) but only forwards to the non-exported QuickNoteActivity on a fresh note, so the edit-by-id
          path is never externally reachable. Its own empty-affinity task + noHistory keep it invisible.
        -->
        <activity
            android:name=".ui.shortcut.NewNoteShortcutActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Stela.Transparent" />

        <service
            android:name=".ui.tile.QuickNoteTileService"
            android:exported="true"
            android:icon="@drawable/ic_stela_pin"
            android:label="@string/qs_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
          Empty taskAffinity + its own task so the popup floats over whatever the user is doing without
          bringing the app's MainActivity task to the foreground behind it. excludeFromRecents keeps the
          transient overlay out of recents; singleTask means a fresh trigger reuses the one instance
          (via onNewIntent) instead of stacking a second popup.
        -->
        <activity
            android:name=".ui.quicknote.QuickNoteActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:theme="@style/Theme.Stela.Transparent"
            android:windowSoftInputMode="adjustResize" />

        <receiver
            android:name=".notifications.NotificationActionReceiver"
            android:exported="false" />

        <receiver
            android:name=".pin.PinAlarmReceiver"
            android:exported="false" />

        <service
            android:name=".pin.PinService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps user-pinned notes posted as ongoing notifications and hosts a quick-add entry. Stela is an offline notes-as-notifications app with no other background work, networking, or data collection." />
        </service>

        <receiver
            android:name=".pin.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".ui.widget.StelaWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stela_widget_info" />
        </receiver>
    </application>

</manifest>
