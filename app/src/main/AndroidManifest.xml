<?xml version="1.0" encoding="utf-8"?>
<!--
  No permissions are declared in Phase 1. INTERNET is never declared (offline by
  design). Foreground-service, notification, and boot permissions arrive in
  Phases 3-4 when first used.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".StelaApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Stela">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Stela">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
