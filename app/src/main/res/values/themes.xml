<resources>
    <!--
      Window theme applied before Compose draws. Material3 DayNight resolves light/dark itself
      and is AppCompat-compatible, which AppCompatActivity (and the emoji search dialog) requires.
      In-app colors come from the Compose theme, which also honors the user's explicit theme choice.
    -->
    <style name="Theme.Stela" parent="Theme.Material3.DayNight.NoActionBar" />

    <!--
      Launch theme: draws the cold-start splash (the launcher icon on the indigo brand colour) and
      then hands off to the app theme. The platform draws a splash only from API 31; core-splashscreen
      backports the same one down to the minimum SDK, so it is identical across versions. No animated
      icon and no keep-on-screen condition, so it shows only as long as startup genuinely takes.
    -->
    <style name="Theme.Stela.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_indigo</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Stela</item>
    </style>

    <!--
      Transparent window for QuickNoteActivity: the activity itself draws nothing, so the screen behind
      shows through; the Compose ModalBottomSheet supplies its own scrim and sheet. backgroundDimEnabled
      is off so the system doesn't dim on top of that scrim.
    -->
    <style name="Theme.Stela.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
