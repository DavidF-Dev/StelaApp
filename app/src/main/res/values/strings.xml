    <!-- About -->
    <string name="about_title">About</string>
    <string name="about_version">Version %1$s</string>
    <string name="about_author">by David F Dev</string>
    <string name="about_privacy_title">Privacy</string>
    <string name="about_privacy_body">Stela is fully offline. No ads, no analytics, and no internet permission — your notes never leave your device.</string>
    <string name="about_how_title">How Stela works</string>
    <string name="about_how_body">Pinned notes self-heal (they re-post if cleared), survive a reboot, and resist being killed in the background. Modern Android can\'t guarantee a truly undismissable notification or an unkillable app, so Stela does the next best thing.</string>
